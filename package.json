{
  "name": "inat-graphs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85",
  "scripts": {
    "generate:inat-types": "swagger2openapi data/inat-swagger.json | openapi-typescript /dev/stdin -o src/lib/inat/schema.d.ts",
    "dev": "pnpm generate:inat-types && next dev -p 8501",
    "build": "pnpm generate:inat-types && next build",
    "start": "next start -p 8501",
    "lint": "eslint",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "update:inat-spec": "tsx scripts/update-inat-spec.ts",
    "update:wingspan-data": "tsx scripts/update-wingspan-data.ts",
    "check-ebird": "tsx scripts/check-ebird.ts"
  },
  "dependencies": {
    "@immich/sdk": "^3.0.3",
    "@mantine/core": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "@phosphor-icons/react": "^2.1.10",
    "env-paths": "^4.0.0",
    "ip-address": "^10.2.0",
    "lodash-es": "^4.18.1",
    "mantine-datatable": "^9.4.0",
    "next": "16.2.10",
    "openapi-fetch": "^0.17.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.13.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "csv-parse": "^7.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.9.5",
    "swagger2openapi": "^7.0.8",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
